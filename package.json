{
  "name": "muonium-stack-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "bench:cli": "node scripts/benchmark-cli.mjs",
    "bench:rust": "cd wasm-core && cargo run --release --bin benchmark --",
    "bench:stockfish": "node scripts/benchmark-stockfish.mjs",
    "bench:stockfish:wasm": "node scripts/benchmark-stockfish-wasm-cli.mjs",
    "bench:stockfish:wasm:1000": "node scripts/benchmark-stockfish-wasm-cli.mjs --games 1000",
    "db:build": "node scripts/build-games-db.mjs",
    "sql:sync": "node scripts/sync-sql-wasm.mjs",
    "stockfish:sync": "node scripts/sync-stockfish-wasm.mjs",
    "dev": "npm run sql:sync && npm run stockfish:sync && npm run wasm:build && vite",
    "dev:full": "npm run db:build && npm run sql:sync && npm run stockfish:sync && npm run wasm:build && vite",
    "build": "npm run db:build && npm run sql:sync && npm run stockfish:sync && npm run wasm:build && vite build",
    "preview": "vite preview",
    "playground:dev": "vite --config simulations/playground/vite.config.js",
    "playground:build": "vite build --config simulations/playground/vite.config.js",
    "playground:preview": "vite preview --config simulations/playground/vite.config.js",
    "playground:bench": "node simulations/playground/scripts/benchmark-playground.mjs",
    "playground:bundle-report": "node simulations/playground/scripts/report-bundle-size.mjs",
    "playground:smoke": "node simulations/playground/scripts/smoke-playground.mjs",
    "wasm:build": "cd wasm-core && PATH=\"$HOME/.cargo/bin:$PATH\" wasm-pack build --target web --out-dir ../web/src/wasm_pkg"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@grafeo-db/wasm": "^0.5.8",
    "chess.js": "^1.4.0",
    "sql.js": "^1.13.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "coi-serviceworker": "^0.1.7",
    "stockfish.wasm": "^0.10.0",
    "vite": "^7.1.3"
  }
}
